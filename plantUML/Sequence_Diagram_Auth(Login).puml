@startuml Auth (Login)

header Massage Reservation Sequence Diagram
footer Page %page% of %lastpage%
title "Auth (Login)"

participant "Client" as client
participant "<<javaScript>>\n:server" as server
participant "<<router>>\n:auth" as routerAuth
participant "<<controllers>>\n:auth" as controllersAuth
participant "<<model>>\n:User" as modelUser
database "<<MongoDB>>\n:users" as UsersDatabase
participant "<<JWT>>\n:tokenService" as jwtService

client -> server ++: req.post('/api/v1/auth/login')
server -> routerAuth ++: app.use('/api/v1/auth', auth)
routerAuth -> controllersAuth ++: login(email, password)
controllersAuth -> modelUser ++: findOne({email})
modelUser -> UsersDatabase ++: UserSchema
UsersDatabase --> modelUser --: user(+password)
controllersAuth -> modelUser ++: matchPassword(password)
controllersAuth -> jwtService ++: getSignedJwtToken()
jwtService --> controllersAuth --: token
controllersAuth -> client --: response(200, token + setCookie)

@enduml