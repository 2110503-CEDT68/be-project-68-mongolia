@startuml Manage Shop (PUT)

header Massage Reservation Sequence Diagram
footer Page %page% of %lastpage%
title "Manage Shop (PUT)"

participant "Client(Admin)" as client
participant "<<javaScript>>\n:server" as server
participant "<<router>>\n:shops" as routerShops
participant "<<middleware>>\n:auth" as authMiddleware
participant "<<controllers>>\n:shops" as controllersShops
participant "<<model>>\n:Shop" as modelShop
database "<<MongoDB>>\n:shops" as ShopsDatabase

client -> server ++: req.put('/api/v1/shops/{id}')
server -> routerShops ++: app.use('/api/v1/shops', shops)
routerShops -> authMiddleware ++: protect(), authorize('admin')
authMiddleware --> routerShops --: next()
routerShops -> controllersShops ++: updateShop(id, req.body)
controllersShops -> modelShop ++: findByIdAndUpdate(id, req.body)
modelShop -> ShopsDatabase ++: ShopSchema
ShopsDatabase --> modelShop --: updatedShop
controllersShops <-- modelShop --: updatedShop
controllersShops -> client --: response(200, updatedShop)

@enduml